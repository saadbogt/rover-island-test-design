{{ 'section-reels-slider.css' | asset_url | stylesheet_tag }}

{%- assign section_id = section.id -%}

{%- style -%}
  /* Dynamic Grid Calculations targeting the specific section ID */
  #ReelsSlider-{{ section_id }} {
    --items-mobile: {{ section.settings.items_mobile | plus: 0.05 }};
    --gap-count-mobile: {{ section.settings.items_mobile }};
  }

  .section-{{ section_id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section_id }}-typography .reels-slider__heading {
    font-size: {{ section.settings.heading_size_mobile }}px;
    line-height: {{ section.settings.heading_line_height }};
  }
  .section-{{ section_id }}-typography .reels-slider__description {
    font-size: {{ section.settings.desc_size_mobile }}px;
    line-height: {{ section.settings.desc_line_height }};
  }

  @media screen and (min-width: 750px) {
    #ReelsSlider-{{ section_id }} {
      --items-tablet: {{ section.settings.items_tablet | plus: 0.1 }};
      --gap-count-tablet: {{ section.settings.items_tablet }};
    }
    
    .section-{{ section_id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .section-{{ section_id }}-typography .reels-slider__heading {
      font-size: {{ section.settings.heading_size_tablet }}px;
    }
    .section-{{ section_id }}-typography .reels-slider__description {
      font-size: {{ section.settings.desc_size_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    #ReelsSlider-{{ section_id }} {
      --items-desktop: {{ section.settings.items_desktop | plus: 0.1 }};
      --gap-count-desktop: {{ section.settings.items_desktop }};
    }
    
    .section-{{ section_id }}-typography .reels-slider__heading {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }
    .section-{{ section_id }}-typography .reels-slider__description {
      font-size: {{ section.settings.desc_size_desktop }}px;
    }
  }
{%- endstyle -%}

<shoppable-reels-slider id="ReelsSlider-{{ section_id }}" class="reels-slider-section section-{{ section_id }}-padding section-{{ section_id }}-typography {% if section.settings.page_width %}page-width{% endif %}">
  
  {%- if section.settings.heading != blank or section.settings.description != blank -%}
    <div class="reels-slider__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="reels-slider__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="reels-slider__description">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="reels-slider__container" style="--grid-gap: {{ section.settings.item_gap }}px;">
    
    <button class="reels-slider__btn prev" aria-label="Previous slide" disabled>
      <svg viewBox="0 0 14 10" fill="none" class="icon icon-arrow" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M8.537.808a.5.5 0 01.817-.162l4 4a.5.5 0 010 .708l-4 4a.5.5 0 11-.708-.708L11.793 5.5H1.5a.5.5 0 010-1h10.293L8.646 1.354a.5.5 0 01-.109-.546z" fill="currentColor" transform="rotate(180 7 5)"></path>
      </svg>
    </button>

    <ul class="reels-slider__track" role="list">
      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}
        
        <li class="reels-slider__slide" {{ block.shopify_attributes }}>
          <a href="{{ product.url | default: '#' }}" class="reels-slider__link" aria-label="{{ product.title | escape }}">
            
            <div class="reels-slider__media-wrapper">
              {%- if block.settings.shopify_video != blank -%}
                {{ block.settings.shopify_video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, image_size: '400x' }}
              {%- elsif block.settings.fallback_image != blank -%}
                {{ block.settings.fallback_image | image_url: width: 400 | image_tag: loading: 'lazy', alt: product.title }}
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

            <div class="reels-slider__info">
              <div class="reels-slider__thumb">
                {%- if product.featured_media -%}
                  {{ product.featured_media | image_url: width: 80 | image_tag: loading: 'lazy', alt: product.title }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>

              <div class="reels-slider__title">
                {{ product.title | default: 'Example Product Title' }}
              </div>
              
              <div class="reels-slider__price-row">
                {%- if product != blank -%}
                  {%- if product.compare_at_price > product.price -%}
                    {%- assign discount_percentage = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
                    <span class="reels-slider__badge">{{ discount_percentage }}% OFF</span>
                    <span class="reels-slider__compare">{{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                  <span class="reels-slider__price">{{ product.price | money }}</span>
                {%- else -%}
                  <span class="reels-slider__badge">30% OFF</span>
                  <span class="reels-slider__compare">$51.00</span>
                  <span class="reels-slider__price">$35.70</span>
                {%- endif -%}
              </div>
            </div>
            
          </a>
        </li>
      {%- endfor -%}
    </ul>

    <button class="reels-slider__btn next" aria-label="Next slide">
      <svg viewBox="0 0 14 10" fill="none" class="icon icon-arrow" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M8.537.808a.5.5 0 01.817-.162l4 4a.5.5 0 010 .708l-4 4a.5.5 0 11-.708-.708L11.793 5.5H1.5a.5.5 0 010-1h10.293L8.646 1.354a.5.5 0 01-.109-.546z" fill="currentColor"></path>
      </svg>
    </button>

  </div>
</shoppable-reels-slider>

<script>
  if (!customElements.get('shoppable-reels-slider')) {
    class ShoppableReelsSlider extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('.reels-slider__track');
        this.prevBtn = this.querySelector('.prev');
        this.nextBtn = this.querySelector('.next');
      }

      connectedCallback() {
        this.initSlider();
        this.initResizeObserver();
      }

      initSlider() {
        if (!this.track) return;

        if (this.prevBtn && this.nextBtn) {
          const scrollAmount = () => this.track.clientWidth * 0.8;
          this.prevBtn.addEventListener('click', () => this.track.scrollBy({ left: -scrollAmount(), behavior: 'smooth' }));
          this.nextBtn.addEventListener('click', () => this.track.scrollBy({ left: scrollAmount(), behavior: 'smooth' }));
        }

        let isDown = false;
        let startX;
        let scrollLeft;
        let isDragging = false;

        const startDrag = (pageX) => {
          isDown = true;
          isDragging = false;
          this.track.classList.add('is-dragging');
          startX = pageX - this.track.offsetLeft;
          scrollLeft = this.track.scrollLeft;
        };

        const stopDrag = () => {
          if (!isDown) return;
          isDown = false;
          this.track.classList.remove('is-dragging');
          setTimeout(() => { isDragging = false; }, 50); 
        };

        const moveDrag = (pageX, e) => {
          if (!isDown) return;
          isDragging = true;
          if (e && e.cancelable) e.preventDefault();
          const x = pageX - this.track.offsetLeft;
          const walk = (x - startX) * 1.5;
          this.track.scrollLeft = scrollLeft - walk;
        };

        this.track.addEventListener('mousedown', (e) => startDrag(e.pageX));
        window.addEventListener('mouseup', stopDrag);
        this.track.addEventListener('mousemove', (e) => moveDrag(e.pageX, e));

        this.track.addEventListener('touchstart', (e) => startDrag(e.touches[0].pageX), { passive: true });
        window.addEventListener('touchend', stopDrag);
        this.track.addEventListener('touchmove', (e) => {
          if (!isDown) return;
          moveDrag(e.touches[0].pageX, null);
        }, { passive: true });

        const links = this.querySelectorAll('.reels-slider__link');
        links.forEach(link => {
          link.addEventListener('click', (e) => {
            if (isDragging) e.preventDefault();
          });
        });

        this.track.addEventListener('scroll', () => this.updateButtons(), { passive: true });
        this.updateButtons();
      }

      initResizeObserver() {
        this.resizeObserver = new ResizeObserver(() => this.updateButtons());
        this.resizeObserver.observe(this);
      }

      disconnectedCallback() {
        if (this.resizeObserver) this.resizeObserver.disconnect();
      }

      updateButtons() {
        if (!this.track) return;
        if (this.prevBtn) this.prevBtn.disabled = this.track.scrollLeft <= 0;
        if (this.nextBtn) {
          const isAtEnd = this.track.scrollLeft + this.track.clientWidth >= this.track.scrollWidth - 2;
          this.nextBtn.disabled = isAtEnd;
        }
      }
    }
    customElements.define('shoppable-reels-slider', ShoppableReelsSlider);
  }
</script>

{% schema %}
{
  "name": "Shoppable Reels Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "page_width",
      "label": "Adapt to theme page width",
      "default": true
    },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    {
      "type": "range",
      "id": "items_desktop",
      "min": 2,
      "max": 10,
      "step": 1,
      "label": "Items to show on Desktop",
      "default": 6
    },
    {
      "type": "range",
      "id": "items_tablet",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Items to show on Tablet",
      "default": 6
    },
    {
      "type": "range",
      "id": "items_mobile",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Items to show on Mobile",
      "default": 3
    },
    {
      "type": "header",
      "content": "Heading Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Our Reels"
    },
    {
      "type": "range", "id": "heading_size_mobile", "min": 16, "max": 60, "step": 1, "unit": "px", "label": "Font Size (Mobile)", "default": 24
    },
    {
      "type": "range", "id": "heading_size_tablet", "min": 16, "max": 60, "step": 1, "unit": "px", "label": "Font Size (Tablet)", "default": 32
    },
    {
      "type": "range", "id": "heading_size_desktop", "min": 16, "max": 60, "step": 1, "unit": "px", "label": "Font Size (Desktop)", "default": 40
    },
    {
      "type": "text", "id": "heading_line_height", "label": "Line Height", "default": "1.2"
    },
    {
      "type": "header",
      "content": "Description Settings"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Short Description"
    },
    {
      "type": "range", "id": "desc_size_mobile", "min": 12, "max": 30, "step": 1, "unit": "px", "label": "Font Size (Mobile)", "default": 14
    },
    {
      "type": "range", "id": "desc_size_tablet", "min": 12, "max": 30, "step": 1, "unit": "px", "label": "Font Size (Tablet)", "default": 16
    },
    {
      "type": "range", "id": "desc_size_desktop", "min": 12, "max": 30, "step": 1, "unit": "px", "label": "Font Size (Desktop)", "default": 16
    },
    {
      "type": "text", "id": "desc_line_height", "label": "Line Height", "default": "1.5"
    },
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "range", "id": "item_gap", "min": 8, "max": 40, "step": 2, "unit": "px", "label": "Item Gap", "default": 16
    },
    {
      "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top", "default": 36
    },
    {
      "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 36
    }
  ],
  "blocks": [
    {
      "type": "reel",
      "name": "Shoppable Reel",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Link Product",
          "info": "The card will link to this product. Details, thumbnail, and pricing pull from here automatically."
        },
        {
          "type": "video",
          "id": "shopify_video",
          "label": "Shopify Hosted Video (Recommended)",
          "info": "Upload an MP4 directly to Shopify. This provides the best native 'Reel' look, autoplay, and ensures drag functionality works perfectly without iframe conflicts."
        },
        {
          "type": "image_picker",
          "id": "fallback_image",
          "label": "Fallback Cover Image",
          "info": "Used if no video is provided, or as a cover for external links."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shoppable Reels Slider",
      "blocks": [
        { "type": "reel" },
        { "type": "reel" },
        { "type": "reel" },
        { "type": "reel" }
      ]
    }
  ]
}
{% endschema %}